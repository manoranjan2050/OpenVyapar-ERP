APP_NAME=OpenVyapar
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=http://localhost:8000

LOG_CHANNEL=single
LOG_LEVEL=error

# SQLite - portable edition (no MySQL needed)
DB_CONNECTION=sqlite
DB_DATABASE=database/openvyapar.sqlite

CACHE_DRIVER=file
SESSION_DRIVER=file
SESSION_LIFETIME=120

SANCTUM_STATEFUL_DOMAINS=localhost:8000
SESSION_DOMAIN=localhost

# Mail - configure in app settings
MAIL_MAILER=log

